
OTEL_SERVICE_NAME=o11y
OTEL_RESOURCE_ATTRIBUTES=service.version=v0.1.0,service.namespace=o11y,deployment.environment=local

### Otel SDK Configuration
# OTEL_SDK_DISABLED=true
# OTEL_LOG_LEVEL=DEBUG
# OTEL_PROPAGATORS=tracecontext,baggage
# OTEL_PRETTY_PRINT=true
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_LOG_HANDLER=otelslog
# OTEL_PROFILES_EXPORTER=pyroscope

### Metrics Configuration
# OTEL_METRICS_EXEMPLAR_FILTER=trace_based
# OTEL_METRIC_EXPORT_INTERVAL=60s
# OTEL_METRIC_EXPORT_TIMEOUT=30s

### Traces Configuration
# OTEL_TRACE_SAMPLER=parentbased_always_on
# OTEL_TRACE_SAMPLER_ARG=1
# OTEL_BSP_SCHEDULE_DELAY=5s
# OTEL_BSP_EXPORT_TIMEOUT=30s
# OTEL_BSP_MAX_QUEUE_SIZE=5120
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=5120
# OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=1024
# OTEL_ATTRIBUTE_COUNT_LIMIT=128
# OTEL_SPAN_ATTRIBUTE_VALUE_LENGTH_LIMIT=1024
# OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT=128
# OTEL_SPAN_EVENT_COUNT_LIMIT=128
# OTEL_EVENT_ATTRIBUTE_COUNT_LIMIT=128
# OTEL_SPAN_LINK_COUNT_LIMIT=128
# OTEL_SPAN_LINK_ATTRIBUTE_COUNT_LIMIT=128

### Logs Configuration
# OTEL_BLRP_SCHEDULE_DELAY=1s
# OTEL_BLRP_EXPORT_TIMEOUT=30s
# OTEL_BLRP_MAX_QUEUE_SIZE=2048
# OTEL_BLRP_MAX_EXPORT_BATCH_SIZE=2048
# OTEL_LOGRECORD_ATTRIBUTE_VALUE_LENGTH_LIMIT=1024
# OTEL_LOGRECORD_ATTRIBUTE_COUNT_LIMIT=128

### Profiles Configuration
# OTEL_PROFILES=cpu,heap,goroutine,mutex
# OTEL_PROFILE_EXPORT_INTERVAL=10s

### OTLP Exporter Configuration
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_EXPORTER_OTLP_TRACES_INSECURE=true
# OTEL_EXPORTER_OTLP_METRICS_INSECURE=true
# OTEL_EXPORTER_OTLP_LOGS_INSECURE=true
